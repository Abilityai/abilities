# pipeline.yaml — generated by /add-pipeline init
# Edit freely. Run /validate-pipeline after changes to regenerate pipeline.lock.json.
schema_version: 1
pipeline_id: {{PIPELINE_ID}}
name: "{{PIPELINE_NAME}}"
description: |
  {{PIPELINE_DESCRIPTION}}

# How instances are discovered. Either explicit list or directory glob.
instances:
  source: directory
  path: projects/{{PIPELINE_ID}}/instances
  status_filter: [active]

# Stage definitions. Add stages via /add-pipeline-stage.
stages:
  - id: example
    skill: replace-me
    timeout_seconds: 600
    retry:
      max_attempts: 2
      backoff_seconds: [60, 300]
    on_failure: escalate
    description: "Replace this with your first stage."

# Transitions. Default = sequential by depends_on. Explicit transitions allow
# branching, parallel fan-out, conditional routing.
transitions: []

# Stage transitions emit Trinity events with these names.
events:
  emit_on_advance: "pipeline.{{PIPELINE_ID}}.{instance}.stage_advanced"
  emit_on_complete: "pipeline.{{PIPELINE_ID}}.{instance}.cycle_completed"
  emit_on_escalation: "pipeline.{{PIPELINE_ID}}.{instance}.escalated"

# Heartbeat that owns the state machine.
heartbeat:
  schedule_name: "pipeline-{{PIPELINE_ID}}-heartbeat"
  cron: "*/15 * * * *"
  skill: pipeline-tick
  pre_check: ~/.trinity/pre-check

# Escalation policy when on_failure: escalate fires.
escalation:
  channel: operator_queue
  priority: high
  template: |
    Pipeline {pipeline_id} instance {instance} stuck at stage {stage}.
    Attempts: {retries}/{max_retries}. Last error: {error_summary}.
    Suggested actions: {suggested_actions}.
  suggested_actions:
    credential_missing: "Inject the missing key via /api/agents/{agent}/credentials/inject"
    subscription_expired: "Refresh subscription in Settings → Subscriptions"
    external_unreachable: "Check connectivity to {url}"
    timeout: "Increase timeout in pipeline.yaml or investigate underlying skill"

# Health rollup — used by dashboard.yaml.
health:
  green_when: "all instances advanced within 24h AND no open escalations"
  yellow_when: "any instance retrying OR last advance > 24h"
  red_when: "any open escalation OR any instance in stage > stage.timeout * 3"
